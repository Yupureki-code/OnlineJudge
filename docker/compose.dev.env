# 复制此文件为 .env 后使用: cp compose.dev.env .env
# ---- 数据库 ----
OJ_DB_HOST=mysql
OJ_DB_PORT=3306
OJ_DB_NAME=myoj
OJ_DB_USER=oj_server
OJ_DB_PASSWD=dev-db-password
OJ_DB_PASS=dev-db-password
OJ_DB_ROOT_PASSWD=dev-root-password
# ---- Redis ----
OJ_REDIS_ADDR=tcp://default:dev-redis-password@redis:6379
OJ_REDIS_PASSWD=dev-redis-password
# ---- RabbitMQ ----
OJ_MQ_HOST=rabbitmq
OJ_MQ_PORT=5672
OJ_MQ_USER=oj-dev
OJ_MQ_PASSWD=dev-mq-password
OJ_MQ_PASS=dev-mq-password
# ---- 应用密钥 ----
OJ_JUDGE_CALLBACK_SECRET=dev-callback-secret-change-before-production
# ---- TLS (本地开发用假文件) ----
OJ_TLS_CERT_PATH=/dev/null
OJ_TLS_KEY_PATH=/dev/null
OJ_REQUIRE_TLS_SECRETS=false
# ---- Gateway ----
OJ_GATEWAY_AUTH_TOKEN_PATH=./dev-gateway-auth-token
OJ_ALLOWED_ORIGINS=http://localhost
# ---- Docker ----
DOCKER_GID=984
