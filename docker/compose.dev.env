OJ_MYSQL_ROOT_PASSWORD=dev-root-password
OJ_DB_PASSWORD=dev-db-password
OJ_REDIS_PASSWORD=dev-redis-password
OJ_REDIS_ADDR=tcp://default:dev-redis-password@redis:6379
OJ_MQ_USER=oj-dev
OJ_MQ_PASSWORD=dev-mq-password
OJ_JUDGE_CALLBACK_SECRET=dev-callback-secret-change-before-production
OJ_TLS_CERT_PATH=/dev/null
OJ_TLS_KEY_PATH=/dev/null
OJ_GATEWAY_AUTH_TOKEN_PATH=./dev-gateway-auth-token
OJ_REQUIRE_TLS_SECRETS=false
DOCKER_GID=984
