if(NOT DEFINED PROTO_DIR)
    message(FATAL_ERROR "PROTO_DIR is required")
endif()

file(GLOB GENERATED_PROTO_FILES "${PROTO_DIR}/*.pb.h" "${PROTO_DIR}/*.pb.cc")
foreach(GENERATED_PROTO_FILE IN LISTS GENERATED_PROTO_FILES)
    file(READ "${GENERATED_PROTO_FILE}" GENERATED_PROTO_CONTENT)
    string(REGEX REPLACE "[ \t]+\n" "\n" GENERATED_PROTO_CONTENT "${GENERATED_PROTO_CONTENT}")
    file(WRITE "${GENERATED_PROTO_FILE}" "${GENERATED_PROTO_CONTENT}")
endforeach()
